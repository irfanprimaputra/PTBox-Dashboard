//@version=6
// ═══════════════════════════════════════════════════════════════════════════
// PT BOX e20d — Final Locked Baseline · Walk-forward +976 / OOS +1206 pts
// XAUUSD intraday · 3-session model differentiated · 2026-05-04
//
// Asia:   Mean-rev A2-fail, late-window 21-23 ET (post-Tokyo, pre-London)
// London: Breakout-pullback + pattern (pin/engulf/inside) at pullback
// NY:     Direct breakout + pattern-at-breakout candle (Naked Forex)
//
// Setup TradingView:
//   - Chart timezone: UTC-4 (NY EDT)
//   - Timeframe: M1 (preferred) or M5
//   - Symbol: XAUUSD
//
// 2026-05-04 update: v5 → v6, fix xloc.bar_index 500-bar limit error,
//                    add per-session stats panel (W/L/Chop/WR/PnL/RR/etc)
// ═══════════════════════════════════════════════════════════════════════════
indicator("PT Box e20d (Phase 7 baseline)", overlay = true,
     max_boxes_count   = 500,
     max_lines_count   = 500,
     max_labels_count  = 500,
     max_bars_back     = 500)

// ─── Display toggles ──────────────────────────────────────────────────────
g_disp = "Display"
showAsia      = input.bool(true, "Show Asia (mean-rev)",            group = g_disp)
showLondon    = input.bool(true, "Show London (breakout-pullback)", group = g_disp)
showNY        = input.bool(true, "Show NY (direct breakout)",       group = g_disp)
showSignals   = input.bool(true, "Show entry signals (labels)",     group = g_disp)
showLevels    = input.bool(true, "Show SL/TP lines on entry",       group = g_disp)
showStatsPanel= input.bool(true, "Show stats panel (top-right)",    group = g_disp)
showInfoPanel = input.bool(false,"Show config info panel (bottom)", group = g_disp)
panelLookback = input.int (90,   "Stats lookback (days)", minval = 1, maxval = 365, group = g_disp)

// ─── e20d Asia (mean-rev A2-fail, late-window 21-23 ET) ────────────────────
g_asia          = "🟢 Asia (e20d late-window)"
asiaBoxStartH   = input.int  (21,  "Box start hour (ET)", minval = 0, maxval = 23, group = g_asia)
asiaBoxStartM   = input.int  (0,   "Box start minute",    minval = 0, maxval = 59, group = g_asia)
asiaBoxDur      = input.int  (7,   "Box duration (min)",  minval = 1, maxval = 60, group = g_asia)
asiaSessionEndH = input.int  (23,  "Session end hour (ET)", minval = 0, maxval = 23, group = g_asia)
asiaSlBuffer    = input.float(1.0, "SL buffer (pts) above breakout extreme", group = g_asia)
asiaMaxAttempt  = input.int  (5,   "Max attempts (adaptive 1W or 2L stops)", group = g_asia)

// ─── London (breakout-pullback + any pattern) ──────────────────────────────
g_london          = "🔵 London (breakout-pullback)"
londonBoxStartH   = input.int  (1,   "Box start hour (ET)", minval = 0, maxval = 23, group = g_london)
londonBoxStartM   = input.int  (43,  "Box start minute",    minval = 0, maxval = 59, group = g_london)
londonBoxDur      = input.int  (3,   "Box duration (min)",  minval = 1, maxval = 60, group = g_london)
londonSessionEndH = input.int  (5,   "Session end hour (ET)", group = g_london)
londonSlBoxMult   = input.float(0.5, "SL = X × box_width", minval = 0.1, maxval = 2.0, step = 0.05, group = g_london)
londonTp1Mult     = input.float(3.0, "TP1 = X × SL", group = g_london)
londonTp2Mult     = input.float(6.0, "TP2 = X × SL", group = g_london)
londonMinSl       = input.float(3.0, "Min SL (pts)", group = g_london)
londonMaxAttempt  = input.int  (3,   "Max attempts/day", group = g_london)

// ─── NY (direct breakout + pattern-at-breakout) ────────────────────────────
g_ny          = "🟡 NY (direct breakout + pattern)"
nyBoxStartH   = input.int  (9,   "Box start hour (ET)", minval = 0, maxval = 23, group = g_ny)
nyBoxStartM   = input.int  (3,   "Box start minute",    minval = 0, maxval = 59, group = g_ny)
nyBoxDur      = input.int  (5,   "Box duration (min)",  minval = 1, maxval = 60, group = g_ny)
nySessionEndH = input.int  (12,  "Session end hour (ET)", group = g_ny)
nySlBoxMult   = input.float(0.5, "SL = X × box_width", group = g_ny)
nyTp1Mult     = input.float(3.0, "TP1 = X × SL", group = g_ny)
nyTp2Mult     = input.float(6.0, "TP2 = X × SL", group = g_ny)
nyMinSl       = input.float(3.0, "Min SL (pts)", group = g_ny)
nyMaxAttempt  = input.int  (3,   "Max attempts/day", group = g_ny)

// ─── Pattern detection (any: pin OR engulfing OR inside_bar) ───────────────
isBullPin(o, h, l, c) =>
    rng       = h - l
    body      = math.abs(c - o)
    lowerWick = math.min(o, c) - l
    rng > 0 and body / rng <= 0.30 and lowerWick / rng >= 0.50

isBearPin(o, h, l, c) =>
    rng       = h - l
    body      = math.abs(c - o)
    upperWick = h - math.max(o, c)
    rng > 0 and body / rng <= 0.30 and upperWick / rng >= 0.50

isBullEngulf(po, pc, o, c) => pc < po and c > o and o <= pc and c >= po
isBearEngulf(po, pc, o, c) => pc > po and c < o and o >= pc and c <= po
isInsideBar (ph, pl, h,  l) => h < ph and l > pl

anyBullPattern(po, ph, pl, pc, o, h, l, c) =>
    isBullPin(o, h, l, c) or isBullEngulf(po, pc, o, c) or isInsideBar(ph, pl, h, l)

anyBearPattern(po, ph, pl, pc, o, h, l, c) =>
    isBearPin(o, h, l, c) or isBearEngulf(po, pc, o, c) or isInsideBar(ph, pl, h, l)

// ─── Time helpers ──────────────────────────────────────────────────────────
minuteOfDayET() => hour(time, "America/New_York") * 60 + minute(time, "America/New_York")
mod = minuteOfDayET()

// Lookback window for stats panel (only count trades from last N days)
inLookback = (time_close > timenow - panelLookback * 86400000)

// ─── Box state per session ─────────────────────────────────────────────────
var float asiaBoxHi    = na
var float asiaBoxLo    = na
var int   asiaBoxBar   = na
var float londonBoxHi  = na
var float londonBoxLo  = na
var int   londonBoxBar = na
var float nyBoxHi      = na
var float nyBoxLo      = na
var int   nyBoxBar     = na

// ─── Box detection: incremental aggregation per session ────────────────────
var float asiaBxHiTmp   = na
var float asiaBxLoTmp   = na
asiaStart = asiaBoxStartH * 60 + asiaBoxStartM
asiaEndW  = asiaStart + asiaBoxDur
asiaInWin = mod >= asiaStart and mod < asiaEndW
asiaJustClosed = mod == asiaEndW
if asiaInWin
    asiaBxHiTmp := na(asiaBxHiTmp) ? high : math.max(asiaBxHiTmp, high)
    asiaBxLoTmp := na(asiaBxLoTmp) ? low  : math.min(asiaBxLoTmp, low)
if asiaJustClosed
    asiaBoxHi  := asiaBxHiTmp
    asiaBoxLo  := asiaBxLoTmp
    asiaBoxBar := bar_index
    asiaBxHiTmp := na
    asiaBxLoTmp := na

var float londonBxHiTmp = na
var float londonBxLoTmp = na
londonStart = londonBoxStartH * 60 + londonBoxStartM
londonEndW  = londonStart + londonBoxDur
londonInWin = mod >= londonStart and mod < londonEndW
londonJustClosed = mod == londonEndW
if londonInWin
    londonBxHiTmp := na(londonBxHiTmp) ? high : math.max(londonBxHiTmp, high)
    londonBxLoTmp := na(londonBxLoTmp) ? low  : math.min(londonBxLoTmp, low)
if londonJustClosed
    londonBoxHi  := londonBxHiTmp
    londonBoxLo  := londonBxLoTmp
    londonBoxBar := bar_index
    londonBxHiTmp := na
    londonBxLoTmp := na

var float nyBxHiTmp = na
var float nyBxLoTmp = na
nyStart = nyBoxStartH * 60 + nyBoxStartM
nyEndW  = nyStart + nyBoxDur
nyInWin = mod >= nyStart and mod < nyEndW
nyJustClosed = mod == nyEndW
if nyInWin
    nyBxHiTmp := na(nyBxHiTmp) ? high : math.max(nyBxHiTmp, high)
    nyBxLoTmp := na(nyBxLoTmp) ? low  : math.min(nyBxLoTmp, low)
if nyJustClosed
    nyBoxHi  := nyBxHiTmp
    nyBoxLo  := nyBxLoTmp
    nyBoxBar := bar_index
    nyBxHiTmp := na
    nyBxLoTmp := na

// ─── Box visualization (use xloc.bar_time to bypass 500-bar limit) ─────────
plotBoxBT(boxHi, boxLo, sessionEndH, col, lbl) =>
    leftT  = time
    rightT = timestamp("America/New_York", year, month, dayofmonth, sessionEndH, 0)
    box.new(left = leftT, top = boxHi, right = rightT, bottom = boxLo,
         xloc          = xloc.bar_time,
         border_color  = col,
         bgcolor       = color.new(col, 90),
         border_width  = 1,
         text          = lbl,
         text_color    = col,
         text_size     = size.tiny)

if showAsia and asiaJustClosed
    plotBoxBT(asiaBoxHi, asiaBoxLo, asiaSessionEndH, color.green,  "Asia (mean-rev)")
if showLondon and londonJustClosed
    plotBoxBT(londonBoxHi, londonBoxLo, londonSessionEndH, color.blue, "London")
if showNY and nyJustClosed
    plotBoxBT(nyBoxHi, nyBoxLo, nySessionEndH, color.orange, "NY (direct)")

// Plot box edges as horizontal line during active session
plot(showAsia   and not na(asiaBoxHi)   and mod < asiaSessionEndH   * 60 ? asiaBoxHi   : na, "Asia Hi",   color = color.green,  style = plot.style_circles, linewidth = 1)
plot(showAsia   and not na(asiaBoxLo)   and mod < asiaSessionEndH   * 60 ? asiaBoxLo   : na, "Asia Lo",   color = color.green,  style = plot.style_circles, linewidth = 1)
plot(showLondon and not na(londonBoxHi) and mod < londonSessionEndH * 60 ? londonBoxHi : na, "London Hi", color = color.blue,   style = plot.style_circles, linewidth = 1)
plot(showLondon and not na(londonBoxLo) and mod < londonSessionEndH * 60 ? londonBoxLo : na, "London Lo", color = color.blue,   style = plot.style_circles, linewidth = 1)
plot(showNY     and not na(nyBoxHi)     and mod < nySessionEndH     * 60 ? nyBoxHi     : na, "NY Hi",     color = color.orange, style = plot.style_circles, linewidth = 1)
plot(showNY     and not na(nyBoxLo)     and mod < nySessionEndH     * 60 ? nyBoxLo     : na, "NY Lo",     color = color.orange, style = plot.style_circles, linewidth = 1)

// ─── Live trade tracking helper (simulate W/L on subsequent bars) ──────────
// State per session: arrays of open trades' SL, TP, dir
type Trade
    float entry
    float sl
    float tp
    int   dir       // +1 long, -1 short
    int   barOpen

// Asia stats (mean-rev: TP=mid, single TP)
var array<Trade> asiaOpen = array.new<Trade>()
var int   asiaTotalWin    = 0
var int   asiaTotalLoss   = 0
var int   asiaChopDays    = 0
var float asiaNetPL       = 0.0
var int   asiaTodayAtt    = 0
var int   asiaBkDir       = 0    // 0=none, 1=up, -1=down
var float asiaExtreme     = na
var bool  asiaHadEntry    = false
var bool  asiaSessionDone = false
var int   asiaLastDay     = -1

// London stats (TP1/TP2)
var array<Trade> londonOpen = array.new<Trade>()
var int   londonTotalWin = 0
var int   londonTotalLoss= 0
var int   londonChopDays = 0
var float londonNetPL    = 0.0
var int   londonTodayAtt = 0
var int   londonBkDir    = 0
var int   londonBkBar    = na
var bool  londonHadEntry = false
var int   londonLastDay  = -1

// NY stats
var array<Trade> nyOpen = array.new<Trade>()
var int   nyTotalWin   = 0
var int   nyTotalLoss  = 0
var int   nyChopDays   = 0
var float nyNetPL      = 0.0
var int   nyTodayAtt   = 0
var bool  nyEntered    = false
var bool  nyHadEntry   = false
var int   nyLastDay    = -1

curDay = dayofmonth(time, "America/New_York")
newDayET = mod == 0  // first M1 bar of new ET day

// New-day reset (Asia)
if newDayET
    if asiaLastDay != -1 and not asiaHadEntry
        asiaChopDays += 1
    asiaLastDay     := curDay
    asiaBkDir       := 0
    asiaExtreme     := na
    asiaTodayAtt    := 0
    asiaHadEntry    := false
    asiaSessionDone := false
    if londonLastDay != -1 and not londonHadEntry
        londonChopDays += 1
    londonLastDay   := curDay
    londonBkDir     := 0
    londonBkBar     := na
    londonTodayAtt  := 0
    londonHadEntry  := false
    if nyLastDay != -1 and not nyHadEntry
        nyChopDays   += 1
    nyLastDay       := curDay
    nyEntered       := false
    nyTodayAtt      := 0
    nyHadEntry      := false

// ─── Simulate close of OPEN trades (check SL/TP hit) ───────────────────────
processOpenTrades(arr, isMeanRev) =>
    int win = 0
    int loss = 0
    float pl = 0.0
    if array.size(arr) > 0
        i = 0
        while i < array.size(arr)
            t = array.get(arr, i)
            if t.dir == 1
                if low <= t.sl
                    loss += 1
                    pl   += t.sl - t.entry
                    array.remove(arr, i)
                    continue
                if high >= t.tp
                    win  += 1
                    pl   += t.tp - t.entry
                    array.remove(arr, i)
                    continue
            else
                if high >= t.sl
                    loss += 1
                    pl   += t.entry - t.sl
                    array.remove(arr, i)
                    continue
                if low <= t.tp
                    win  += 1
                    pl   += t.entry - t.tp
                    array.remove(arr, i)
                    continue
            i += 1
    [win, loss, pl]

[asiaW, asiaL, asiaP]    = processOpenTrades(asiaOpen,   true)
[londonW, londonL, londonP] = processOpenTrades(londonOpen, false)
[nyW, nyL, nyP]          = processOpenTrades(nyOpen,     false)

if inLookback
    asiaTotalWin   += asiaW
    asiaTotalLoss  += asiaL
    asiaNetPL      += asiaP
    londonTotalWin += londonW
    londonTotalLoss+= londonL
    londonNetPL    += londonP
    nyTotalWin     += nyW
    nyTotalLoss    += nyL
    nyNetPL        += nyP

// ─── Asia entry: A2-fail mean-reversion ────────────────────────────────────
inAsiaSession = mod >= asiaEndW and mod < asiaSessionEndH * 60

if showAsia and inAsiaSession and not na(asiaBoxHi) and not asiaSessionDone
    // Adaptive: stop after 1W or 2L this session
    asiaSessionDone := asiaTodayAtt >= asiaMaxAttempt or (asiaTodayAtt > 0 and asiaW > 0) or asiaL >= 2 ? true : asiaSessionDone

if showAsia and inAsiaSession and not na(asiaBoxHi) and not asiaSessionDone
    if asiaBkDir == 0
        if close > asiaBoxHi
            asiaBkDir   := 1
            asiaExtreme := high
        else if close < asiaBoxLo
            asiaBkDir   := -1
            asiaExtreme := low
    else if asiaBkDir == 1
        asiaExtreme := math.max(asiaExtreme, high)
        if close < asiaBoxHi and close > asiaBoxLo
            // Fail → fade short
            if asiaTodayAtt < asiaMaxAttempt
                asiaTodayAtt += 1
                asiaHadEntry := true
                boxMid = (asiaBoxHi + asiaBoxLo) / 2.0
                slPx   = asiaExtreme + asiaSlBuffer
                tpPx   = boxMid
                t = Trade.new(close, slPx, tpPx, -1, bar_index)
                array.push(asiaOpen, t)
                if showSignals
                    label.new(bar_index, high, "Asia Fade ▼\nSL "+str.tostring(slPx,"#.##")+"\nTP "+str.tostring(tpPx,"#.##"),
                         color = color.green, textcolor = color.white, style = label.style_label_down, size = size.small)
                if showLevels
                    line.new(bar_index, slPx, bar_index + 30, slPx, color = color.red,   width = 1, style = line.style_dashed)
                    line.new(bar_index, tpPx, bar_index + 30, tpPx, color = color.green, width = 1, style = line.style_dashed)
                alert("Asia FADE SHORT @ "+str.tostring(close)+" | SL "+str.tostring(slPx)+" | TP "+str.tostring(tpPx), alert.freq_once_per_bar)
            asiaBkDir   := 0
            asiaExtreme := na
    else if asiaBkDir == -1
        asiaExtreme := math.min(asiaExtreme, low)
        if close > asiaBoxLo and close < asiaBoxHi
            if asiaTodayAtt < asiaMaxAttempt
                asiaTodayAtt += 1
                asiaHadEntry := true
                boxMid = (asiaBoxHi + asiaBoxLo) / 2.0
                slPx   = asiaExtreme - asiaSlBuffer
                tpPx   = boxMid
                t = Trade.new(close, slPx, tpPx, 1, bar_index)
                array.push(asiaOpen, t)
                if showSignals
                    label.new(bar_index, low, "Asia Fade ▲\nSL "+str.tostring(slPx,"#.##")+"\nTP "+str.tostring(tpPx,"#.##"),
                         color = color.green, textcolor = color.white, style = label.style_label_up, size = size.small)
                if showLevels
                    line.new(bar_index, slPx, bar_index + 30, slPx, color = color.red,   width = 1, style = line.style_dashed)
                    line.new(bar_index, tpPx, bar_index + 30, tpPx, color = color.green, width = 1, style = line.style_dashed)
                alert("Asia FADE LONG @ "+str.tostring(close)+" | SL "+str.tostring(slPx)+" | TP "+str.tostring(tpPx), alert.freq_once_per_bar)
            asiaBkDir   := 0
            asiaExtreme := na

// ─── London entry: breakout-pullback + any pattern ─────────────────────────
inLondonSession = mod >= londonEndW and mod < londonSessionEndH * 60

if showLondon and inLondonSession and not na(londonBoxHi) and londonTodayAtt < londonMaxAttempt
    if londonBkDir == 0
        if close > londonBoxHi
            londonBkDir := 1
            londonBkBar := bar_index
        else if close < londonBoxLo
            londonBkDir := -1
            londonBkBar := bar_index
    else if londonBkDir == 1 and bar_index > londonBkBar
        if low <= londonBoxHi and close > londonBoxHi
            if anyBullPattern(open[1], high[1], low[1], close[1], open, high, low, close)
                bw      = londonBoxHi - londonBoxLo
                slDist  = math.max(londonMinSl, londonSlBoxMult * bw)
                slPx    = low - slDist
                tp1Px   = close + londonTp1Mult * slDist
                tp2Px   = close + londonTp2Mult * slDist
                londonTodayAtt += 1
                londonHadEntry := true
                t = Trade.new(close, slPx, tp2Px, 1, bar_index)
                array.push(londonOpen, t)
                if showSignals
                    label.new(bar_index, low, "London ▲\nSL "+str.tostring(slPx,"#.##")+"\nTP1 "+str.tostring(tp1Px,"#.##")+"\nTP2 "+str.tostring(tp2Px,"#.##"),
                         color = color.blue, textcolor = color.white, style = label.style_label_up, size = size.small)
                if showLevels
                    line.new(bar_index, slPx,  bar_index + 30, slPx,  color = color.red,   width = 1, style = line.style_dashed)
                    line.new(bar_index, tp1Px, bar_index + 30, tp1Px, color = color.lime,  width = 1, style = line.style_dashed)
                    line.new(bar_index, tp2Px, bar_index + 30, tp2Px, color = color.green, width = 1, style = line.style_dashed)
                alert("London LONG @ "+str.tostring(close)+" | SL "+str.tostring(slPx)+" | TP1 "+str.tostring(tp1Px)+" | TP2 "+str.tostring(tp2Px), alert.freq_once_per_bar)
                londonBkDir := 0
    else if londonBkDir == -1 and bar_index > londonBkBar
        if high >= londonBoxLo and close < londonBoxLo
            if anyBearPattern(open[1], high[1], low[1], close[1], open, high, low, close)
                bw      = londonBoxHi - londonBoxLo
                slDist  = math.max(londonMinSl, londonSlBoxMult * bw)
                slPx    = high + slDist
                tp1Px   = close - londonTp1Mult * slDist
                tp2Px   = close - londonTp2Mult * slDist
                londonTodayAtt += 1
                londonHadEntry := true
                t = Trade.new(close, slPx, tp2Px, -1, bar_index)
                array.push(londonOpen, t)
                if showSignals
                    label.new(bar_index, high, "London ▼\nSL "+str.tostring(slPx,"#.##")+"\nTP1 "+str.tostring(tp1Px,"#.##")+"\nTP2 "+str.tostring(tp2Px,"#.##"),
                         color = color.blue, textcolor = color.white, style = label.style_label_down, size = size.small)
                if showLevels
                    line.new(bar_index, slPx,  bar_index + 30, slPx,  color = color.red,   width = 1, style = line.style_dashed)
                    line.new(bar_index, tp1Px, bar_index + 30, tp1Px, color = color.lime,  width = 1, style = line.style_dashed)
                    line.new(bar_index, tp2Px, bar_index + 30, tp2Px, color = color.green, width = 1, style = line.style_dashed)
                alert("London SHORT @ "+str.tostring(close)+" | SL "+str.tostring(slPx)+" | TP1 "+str.tostring(tp1Px)+" | TP2 "+str.tostring(tp2Px), alert.freq_once_per_bar)
                londonBkDir := 0

// ─── NY entry: direct breakout + pattern-at-breakout ───────────────────────
inNYSession = mod >= nyEndW and mod < nySessionEndH * 60

if showNY and inNYSession and not na(nyBoxHi) and not nyEntered and nyTodayAtt < nyMaxAttempt
    if close > nyBoxHi and anyBullPattern(open[1], high[1], low[1], close[1], open, high, low, close)
        bw     = nyBoxHi - nyBoxLo
        slDist = math.max(nyMinSl, nySlBoxMult * bw)
        slPx   = nyBoxLo - slDist
        tp1Px  = close + nyTp1Mult * slDist
        tp2Px  = close + nyTp2Mult * slDist
        nyTodayAtt += 1
        nyHadEntry := true
        nyEntered  := true
        t = Trade.new(close, slPx, tp2Px, 1, bar_index)
        array.push(nyOpen, t)
        if showSignals
            label.new(bar_index, low, "NY ▲ DIRECT\nSL "+str.tostring(slPx,"#.##")+"\nTP1 "+str.tostring(tp1Px,"#.##")+"\nTP2 "+str.tostring(tp2Px,"#.##"),
                 color = color.orange, textcolor = color.white, style = label.style_label_up, size = size.small)
        if showLevels
            line.new(bar_index, slPx,  bar_index + 30, slPx,  color = color.red,   width = 1, style = line.style_dashed)
            line.new(bar_index, tp1Px, bar_index + 30, tp1Px, color = color.lime,  width = 1, style = line.style_dashed)
            line.new(bar_index, tp2Px, bar_index + 30, tp2Px, color = color.green, width = 1, style = line.style_dashed)
        alert("NY DIRECT LONG @ "+str.tostring(close)+" | SL "+str.tostring(slPx)+" | TP1 "+str.tostring(tp1Px)+" | TP2 "+str.tostring(tp2Px), alert.freq_once_per_bar)
    else if close < nyBoxLo and anyBearPattern(open[1], high[1], low[1], close[1], open, high, low, close)
        bw     = nyBoxHi - nyBoxLo
        slDist = math.max(nyMinSl, nySlBoxMult * bw)
        slPx   = nyBoxHi + slDist
        tp1Px  = close - nyTp1Mult * slDist
        tp2Px  = close - nyTp2Mult * slDist
        nyTodayAtt += 1
        nyHadEntry := true
        nyEntered  := true
        t = Trade.new(close, slPx, tp2Px, -1, bar_index)
        array.push(nyOpen, t)
        if showSignals
            label.new(bar_index, high, "NY ▼ DIRECT\nSL "+str.tostring(slPx,"#.##")+"\nTP1 "+str.tostring(tp1Px,"#.##")+"\nTP2 "+str.tostring(tp2Px,"#.##"),
                 color = color.orange, textcolor = color.white, style = label.style_label_down, size = size.small)
        if showLevels
            line.new(bar_index, slPx,  bar_index + 30, slPx,  color = color.red,   width = 1, style = line.style_dashed)
            line.new(bar_index, tp1Px, bar_index + 30, tp1Px, color = color.lime,  width = 1, style = line.style_dashed)
            line.new(bar_index, tp2Px, bar_index + 30, tp2Px, color = color.green, width = 1, style = line.style_dashed)
        alert("NY DIRECT SHORT @ "+str.tostring(close)+" | SL "+str.tostring(slPx)+" | TP1 "+str.tostring(tp1Px)+" | TP2 "+str.tostring(tp2Px), alert.freq_once_per_bar)

// ─── Stats Panel (per session, top-right) ──────────────────────────────────
if showStatsPanel and barstate.islast
    var table stats = table.new(position.top_right, 4, 13,
         bgcolor      = color.new(color.black, 70),
         border_color = color.new(color.purple, 50),
         border_width = 1)

    // Header row
    table.cell(stats, 0, 0, "PT BOX", text_color = color.yellow,  bgcolor = color.new(color.purple, 60), text_size = size.small)
    table.cell(stats, 1, 0, "ASIA",   text_color = color.lime,    bgcolor = color.new(color.purple, 60), text_size = size.small)
    table.cell(stats, 2, 0, "LONDON", text_color = color.aqua,    bgcolor = color.new(color.purple, 60), text_size = size.small)
    table.cell(stats, 3, 0, "NY",     text_color = color.orange,  bgcolor = color.new(color.purple, 60), text_size = size.small)

    // Total Win
    table.cell(stats, 0, 1, "Total Win",  text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 1, str.tostring(asiaTotalWin),   text_color = color.lime, text_size = size.tiny)
    table.cell(stats, 2, 1, str.tostring(londonTotalWin), text_color = color.lime, text_size = size.tiny)
    table.cell(stats, 3, 1, str.tostring(nyTotalWin),     text_color = color.lime, text_size = size.tiny)

    // Total Loss
    table.cell(stats, 0, 2, "Total Loss", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 2, str.tostring(asiaTotalLoss),   text_color = color.red, text_size = size.tiny)
    table.cell(stats, 2, 2, str.tostring(londonTotalLoss), text_color = color.red, text_size = size.tiny)
    table.cell(stats, 3, 2, str.tostring(nyTotalLoss),     text_color = color.red, text_size = size.tiny)

    // Chop Days
    table.cell(stats, 0, 3, "Chop Days", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 3, str.tostring(asiaChopDays),   text_color = color.yellow, text_size = size.tiny)
    table.cell(stats, 2, 3, str.tostring(londonChopDays), text_color = color.yellow, text_size = size.tiny)
    table.cell(stats, 3, 3, str.tostring(nyChopDays),     text_color = color.yellow, text_size = size.tiny)

    // Win Rate
    asiaWR   = asiaTotalWin   + asiaTotalLoss   > 0 ? 100.0 * asiaTotalWin   / (asiaTotalWin   + asiaTotalLoss)   : 0
    londonWR = londonTotalWin + londonTotalLoss > 0 ? 100.0 * londonTotalWin / (londonTotalWin + londonTotalLoss) : 0
    nyWR     = nyTotalWin     + nyTotalLoss     > 0 ? 100.0 * nyTotalWin     / (nyTotalWin     + nyTotalLoss)     : 0
    table.cell(stats, 0, 4, "Win Rate", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 4, str.tostring(asiaWR,"#.#")+"%",   text_color = asiaWR   >= 50 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 2, 4, str.tostring(londonWR,"#.#")+"%", text_color = londonWR >= 50 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 3, 4, str.tostring(nyWR,"#.#")+"%",     text_color = nyWR     >= 50 ? color.lime : color.red, text_size = size.tiny)

    // Net P&L (pts)
    table.cell(stats, 0, 5, "Net P&L (pts)", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 5, str.tostring(asiaNetPL,"#.#"),   text_color = asiaNetPL   >= 0 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 2, 5, str.tostring(londonNetPL,"#.#"), text_color = londonNetPL >= 0 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 3, 5, str.tostring(nyNetPL,"#.#"),     text_color = nyNetPL     >= 0 ? color.lime : color.red, text_size = size.tiny)

    // RR (TP2/SL)
    table.cell(stats, 0, 6, "RR (TP/SL)", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 6, "1:1.5",                                    text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 6, "1:"+str.tostring(londonTp2Mult,"#.#"),     text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 6, "1:"+str.tostring(nyTp2Mult,"#.#"),         text_color = color.white, text_size = size.tiny)

    // SL/TP1/TP2
    table.cell(stats, 0, 7, "SL/TP1/TP2", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 7, "ext+1 / mid",                              text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 7, "0.5×bw / 3R / 6R",                         text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 7, "0.5×bw / 3R / 6R",                         text_color = color.white, text_size = size.tiny)

    // Max Attempt
    table.cell(stats, 0, 8, "Max Attempt", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 8, str.tostring(asiaMaxAttempt)+"x",    text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 8, str.tostring(londonMaxAttempt)+"x",  text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 8, str.tostring(nyMaxAttempt)+"x",      text_color = color.white, text_size = size.tiny)

    // Today Attempt
    table.cell(stats, 0, 9, "Today Attempt", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 9, str.tostring(asiaTodayAtt)+"/"+str.tostring(asiaMaxAttempt),    text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 9, str.tostring(londonTodayAtt)+"/"+str.tostring(londonMaxAttempt),text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 9, str.tostring(nyTodayAtt)+"/"+str.tostring(nyMaxAttempt),        text_color = color.white, text_size = size.tiny)

    // Breakout Dir
    asiaDirStr   = asiaBkDir   == 1 ? "LONG" : asiaBkDir   == -1 ? "SHORT" : "—"
    londonDirStr = londonBkDir == 1 ? "LONG" : londonBkDir == -1 ? "SHORT" : "—"
    nyDirStr     = nyEntered ? "FIRED" : "—"
    table.cell(stats, 0, 10, "Breakout Dir", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 10, asiaDirStr,   text_color = asiaBkDir   == 1 ? color.lime : asiaBkDir   == -1 ? color.red : color.gray, text_size = size.tiny)
    table.cell(stats, 2, 10, londonDirStr, text_color = londonBkDir == 1 ? color.lime : londonBkDir == -1 ? color.red : color.gray, text_size = size.tiny)
    table.cell(stats, 3, 10, nyDirStr,     text_color = nyEntered ? color.orange : color.gray, text_size = size.tiny)

    // In Trade
    asiaInTrade   = array.size(asiaOpen)   > 0
    londonInTrade = array.size(londonOpen) > 0
    nyInTrade     = array.size(nyOpen)     > 0
    table.cell(stats, 0, 11, "In Trade", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 11, asiaInTrade   ? "YES" : "NO", text_color = asiaInTrade   ? color.lime : color.gray, text_size = size.tiny)
    table.cell(stats, 2, 11, londonInTrade ? "YES" : "NO", text_color = londonInTrade ? color.lime : color.gray, text_size = size.tiny)
    table.cell(stats, 3, 11, nyInTrade     ? "YES" : "NO", text_color = nyInTrade     ? color.lime : color.gray, text_size = size.tiny)

    // Footer (lookback note)
    table.cell(stats, 0, 12, "Lookback",                              text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 12, str.tostring(panelLookback)+"d",         text_color = color.aqua, text_size = size.tiny)
    table.cell(stats, 2, 12, "e20d",                                  text_color = color.yellow, text_size = size.tiny)
    table.cell(stats, 3, 12, "+976/+1206",                            text_color = color.lime, text_size = size.tiny)

// ─── Optional small info panel (bottom-right) ──────────────────────────────
if showInfoPanel and barstate.islast
    var table info = table.new(position.bottom_right, 2, 5,
         bgcolor = color.new(color.black, 80), border_color = color.gray, border_width = 1)
    table.cell(info, 0, 0, "PT Box e20d",       text_color = color.yellow, bgcolor = color.new(color.black, 70))
    table.cell(info, 1, 0, "+976 / +1206 OOS",  text_color = color.lime,   bgcolor = color.new(color.black, 70))
    table.cell(info, 0, 1, "Asia 21-23 ET",     text_color = color.green)
    table.cell(info, 1, 1, "Mean-rev fade",     text_color = color.white)
    table.cell(info, 0, 2, "London 1-5 ET",     text_color = color.blue)
    table.cell(info, 1, 2, "Pullback + pattern",text_color = color.white)
    table.cell(info, 0, 3, "NY 9-12 ET",        text_color = color.orange)
    table.cell(info, 1, 3, "Direct + pattern",  text_color = color.white)
    table.cell(info, 0, 4, "Lot @ $200 cap",    text_color = color.gray)
    table.cell(info, 1, 4, "0.02",              text_color = color.aqua)
