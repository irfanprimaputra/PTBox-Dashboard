//@version=6
// ═══════════════════════════════════════════════════════════════════════════
// PT BOX e20d — Final Locked Baseline · Walk-forward +976 / OOS +1206 pts
// XAUUSD intraday · 3-session model differentiated · 2026-05-04
//
// Asia:   Mean-rev A2-fail, late-window 21-23 ET (post-Tokyo, pre-London)
// London: Breakout-pullback + pattern (pin/engulf/inside) at pullback
// NY:     Direct breakout + pattern-at-breakout candle (Naked Forex)
//
// Setup TradingView:
//   - Chart timezone: UTC-4 (NY EDT)
//   - Timeframe: M1 (preferred) or M5
//   - Symbol: XAUUSD
//
// 2026-05-04 v9: stats panel TODAY mode (realtime, not 90d cumulative)
//                + de-clutter labels (delete on exit, keep lines + W/L marker)
//                + minimal-mode toggle for cleaner multi-entry sessions
//
// ENTRY TIMING (LIVE):
//   - Signal fires at CLOSE of confirmation candle (alert pushed to phone)
//   - Realistic live entry: OPEN of NEXT candle (1 bar after alert)
//   - Backtest assumes entry @ close[N] (zero slippage for engine truth)
//   - Live slippage ~0-2 pts vs backtest is normal
// ═══════════════════════════════════════════════════════════════════════════
indicator("PT Box e20d (Phase 7 baseline)", overlay = true,
     max_boxes_count   = 500,
     max_lines_count   = 500,
     max_labels_count  = 500,
     max_bars_back     = 500)

// ─── Display toggles ──────────────────────────────────────────────────────
g_disp = "Display"
showAsia       = input.bool(true,  "Show Asia (mean-rev)",            group = g_disp)
showLondon     = input.bool(true,  "Show London (breakout-pullback)", group = g_disp)
showNY         = input.bool(true,  "Show NY (direct breakout)",       group = g_disp)
showSignals    = input.bool(true,  "Show entry signals (labels)",     group = g_disp)
showLevels     = input.bool(true,  "Show SL/TP lines (dynamic length)", group = g_disp)
showExitMarker = input.bool(true,  "Show W/L exit markers",           group = g_disp)
hideOldBoxes   = input.bool(false, "Hide boxes after session ends",   group = g_disp)
showStatsPanel = input.bool(true,  "Show stats panel (top-right)",    group = g_disp)
statsMode      = input.string("Today", "Stats mode", options = ["Today", "Cumulative"], group = g_disp)
showInfoPanel  = input.bool(false, "Show config info panel (bottom)", group = g_disp)
panelLookback  = input.int (90,    "Cumulative lookback (days)", minval = 1, maxval = 365, group = g_disp)
boxOpacity     = input.int (92,    "Box fill transparency (90=dark, 95=subtle)", minval = 80, maxval = 99, group = g_disp)
minimalLabels  = input.bool(false, "Minimal label mode (less crowded)", group = g_disp)

// ─── 💰 Risk Management (LIVE filter — does NOT affect backtest engine) ────
g_risk          = "💰 Risk Management (LIVE)"
useMaxSlFilter  = input.bool(true,  "Enable max-SL filter (skip wide-SL trades)",       group = g_risk)
maxSlPts        = input.float(10,   "Max SL distance allowed (pts)", minval = 3,        group = g_risk)
capUsd          = input.float(200,  "Account capital (USD)",                            group = g_risk)
riskPerTradeUsd = input.float(4,    "Max risk per trade (USD) — 2% rule",               group = g_risk)
showLotSuggest  = input.bool(true,  "Show suggested lot in entry label",                group = g_risk)

// ─── e20d Asia (mean-rev A2-fail, late-window 21-23 ET) ────────────────────
g_asia          = "🟢 Asia (e20d late-window)"
asiaBoxStartH   = input.int  (21,  "Box start hour (ET)", minval = 0, maxval = 23, group = g_asia)
asiaBoxStartM   = input.int  (0,   "Box start minute",    minval = 0, maxval = 59, group = g_asia)
asiaBoxDur      = input.int  (7,   "Box duration (min)",  minval = 1, maxval = 60, group = g_asia)
asiaSessionEndH = input.int  (23,  "Session end hour (ET)", minval = 0, maxval = 23, group = g_asia)
asiaSlBuffer    = input.float(1.0, "SL buffer (pts) above breakout extreme", group = g_asia)
asiaMaxAttempt  = input.int  (5,   "Max attempts (adaptive 1W or 2L stops)", group = g_asia)

// ─── London (breakout-pullback + any pattern) ──────────────────────────────
g_london          = "🔵 London (breakout-pullback)"
londonBoxStartH   = input.int  (1,   "Box start hour (ET)", minval = 0, maxval = 23, group = g_london)
londonBoxStartM   = input.int  (43,  "Box start minute",    minval = 0, maxval = 59, group = g_london)
londonBoxDur      = input.int  (3,   "Box duration (min)",  minval = 1, maxval = 60, group = g_london)
londonSessionEndH = input.int  (5,   "Session end hour (ET)", group = g_london)
londonSlBoxMult   = input.float(0.5, "SL = X × box_width", minval = 0.1, maxval = 2.0, step = 0.05, group = g_london)
londonTp1Mult     = input.float(3.0, "TP1 = X × SL", group = g_london)
londonTp2Mult     = input.float(6.0, "TP2 = X × SL", group = g_london)
londonMinSl       = input.float(3.0, "Min SL (pts)", group = g_london)
londonMaxAttempt  = input.int  (3,   "Max attempts/day", group = g_london)

// ─── NY (direct breakout + pattern-at-breakout) ────────────────────────────
g_ny          = "🟡 NY (direct breakout + pattern)"
nyBoxStartH   = input.int  (9,   "Box start hour (ET)", minval = 0, maxval = 23, group = g_ny)
nyBoxStartM   = input.int  (3,   "Box start minute",    minval = 0, maxval = 59, group = g_ny)
nyBoxDur      = input.int  (5,   "Box duration (min)",  minval = 1, maxval = 60, group = g_ny)
nySessionEndH = input.int  (12,  "Session end hour (ET)", group = g_ny)
nySlBoxMult   = input.float(0.5, "SL = X × box_width", group = g_ny)
nyTp1Mult     = input.float(3.0, "TP1 = X × SL", group = g_ny)
nyTp2Mult     = input.float(6.0, "TP2 = X × SL", group = g_ny)
nyMinSl       = input.float(3.0, "Min SL (pts)", group = g_ny)
nyMaxAttempt  = input.int  (3,   "Max attempts/day", group = g_ny)

// ─── Pattern detection ─────────────────────────────────────────────────────
isBullPin(o, h, l, c) =>
    rng       = h - l
    body      = math.abs(c - o)
    lowerWick = math.min(o, c) - l
    rng > 0 and body / rng <= 0.30 and lowerWick / rng >= 0.50

isBearPin(o, h, l, c) =>
    rng       = h - l
    body      = math.abs(c - o)
    upperWick = h - math.max(o, c)
    rng > 0 and body / rng <= 0.30 and upperWick / rng >= 0.50

isBullEngulf(po, pc, o, c) => pc < po and c > o and o <= pc and c >= po
isBearEngulf(po, pc, o, c) => pc > po and c < o and o >= pc and c <= po
isInsideBar (ph, pl, h,  l) => h < ph and l > pl

anyBullPattern(po, ph, pl, pc, o, h, l, c) =>
    isBullPin(o, h, l, c) or isBullEngulf(po, pc, o, c) or isInsideBar(ph, pl, h, l)

anyBearPattern(po, ph, pl, pc, o, h, l, c) =>
    isBearPin(o, h, l, c) or isBearEngulf(po, pc, o, c) or isInsideBar(ph, pl, h, l)

// ─── Time helpers ──────────────────────────────────────────────────────────
minuteOfDayET() => hour(time, "America/New_York") * 60 + minute(time, "America/New_York")
mod = minuteOfDayET()

inLookback = (time_close > timenow - panelLookback * 86400000)

// ─── Box state per session ─────────────────────────────────────────────────
var float asiaBoxHi    = na
var float asiaBoxLo    = na
var int   asiaBoxBar   = na
var box   asiaBoxObj   = na
var bool  asiaBoxDrawn = false

var float londonBoxHi    = na
var float londonBoxLo    = na
var int   londonBoxBar   = na
var box   londonBoxObj   = na
var bool  londonBoxDrawn = false

var float nyBoxHi    = na
var float nyBoxLo    = na
var int   nyBoxBar   = na
var box   nyBoxObj   = na
var bool  nyBoxDrawn = false

// ─── Box detection ─────────────────────────────────────────────────────────
var float asiaBxHiTmp = na
var float asiaBxLoTmp = na
asiaStart      = asiaBoxStartH * 60 + asiaBoxStartM
asiaEndW       = asiaStart + asiaBoxDur
asiaInWin      = mod >= asiaStart and mod < asiaEndW
asiaJustClosed = mod == asiaEndW
if asiaInWin
    asiaBxHiTmp := na(asiaBxHiTmp) ? high : math.max(asiaBxHiTmp, high)
    asiaBxLoTmp := na(asiaBxLoTmp) ? low  : math.min(asiaBxLoTmp, low)
if asiaJustClosed
    asiaBoxHi   := asiaBxHiTmp
    asiaBoxLo   := asiaBxLoTmp
    asiaBoxBar  := bar_index
    asiaBxHiTmp := na
    asiaBxLoTmp := na

var float londonBxHiTmp = na
var float londonBxLoTmp = na
londonStart      = londonBoxStartH * 60 + londonBoxStartM
londonEndW       = londonStart + londonBoxDur
londonInWin      = mod >= londonStart and mod < londonEndW
londonJustClosed = mod == londonEndW
if londonInWin
    londonBxHiTmp := na(londonBxHiTmp) ? high : math.max(londonBxHiTmp, high)
    londonBxLoTmp := na(londonBxLoTmp) ? low  : math.min(londonBxLoTmp, low)
if londonJustClosed
    londonBoxHi   := londonBxHiTmp
    londonBoxLo   := londonBxLoTmp
    londonBoxBar  := bar_index
    londonBxHiTmp := na
    londonBxLoTmp := na

var float nyBxHiTmp = na
var float nyBxLoTmp = na
nyStart      = nyBoxStartH * 60 + nyBoxStartM
nyEndW       = nyStart + nyBoxDur
nyInWin      = mod >= nyStart and mod < nyEndW
nyJustClosed = mod == nyEndW
if nyInWin
    nyBxHiTmp := na(nyBxHiTmp) ? high : math.max(nyBxHiTmp, high)
    nyBxLoTmp := na(nyBxLoTmp) ? low  : math.min(nyBxLoTmp, low)
if nyJustClosed
    nyBoxHi   := nyBxHiTmp
    nyBoxLo   := nyBxLoTmp
    nyBoxBar  := bar_index
    nyBxHiTmp := na
    nyBxLoTmp := na

// ─── Dynamic Box rendering (bar_index based, extend right per bar) ────────
inAsiaSessionRange   = mod >= asiaStart   and mod < asiaSessionEndH   * 60
inLondonSessionRange = mod >= londonStart and mod < londonSessionEndH * 60
inNYSessionRange     = mod >= nyStart     and mod < nySessionEndH     * 60

// Asia
if showAsia and asiaJustClosed
    asiaBoxObj := box.new(left = bar_index - asiaBoxDur, top = asiaBoxHi,
         right = bar_index, bottom = asiaBoxLo,
         border_color = color.green, bgcolor = color.new(color.green, boxOpacity),
         border_width = 1, text = "Asia (mean-rev)", text_color = color.green, text_size = size.tiny)
    asiaBoxDrawn := true
if showAsia and asiaBoxDrawn and inAsiaSessionRange and not na(asiaBoxObj)
    box.set_right(asiaBoxObj, bar_index)
if asiaBoxDrawn and not inAsiaSessionRange and mod < asiaStart
    asiaBoxDrawn := false
    if hideOldBoxes and not na(asiaBoxObj)
        box.delete(asiaBoxObj)

// London
if showLondon and londonJustClosed
    londonBoxObj := box.new(left = bar_index - londonBoxDur, top = londonBoxHi,
         right = bar_index, bottom = londonBoxLo,
         border_color = color.blue, bgcolor = color.new(color.blue, boxOpacity),
         border_width = 1, text = "London", text_color = color.blue, text_size = size.tiny)
    londonBoxDrawn := true
if showLondon and londonBoxDrawn and inLondonSessionRange and not na(londonBoxObj)
    box.set_right(londonBoxObj, bar_index)
if londonBoxDrawn and not inLondonSessionRange and mod < londonStart
    londonBoxDrawn := false
    if hideOldBoxes and not na(londonBoxObj)
        box.delete(londonBoxObj)

// NY
if showNY and nyJustClosed
    nyBoxObj := box.new(left = bar_index - nyBoxDur, top = nyBoxHi,
         right = bar_index, bottom = nyBoxLo,
         border_color = color.orange, bgcolor = color.new(color.orange, boxOpacity),
         border_width = 1, text = "NY (direct)", text_color = color.orange, text_size = size.tiny)
    nyBoxDrawn := true
if showNY and nyBoxDrawn and inNYSessionRange and not na(nyBoxObj)
    box.set_right(nyBoxObj, bar_index)
if nyBoxDrawn and not inNYSessionRange and mod < nyStart
    nyBoxDrawn := false
    if hideOldBoxes and not na(nyBoxObj)
        box.delete(nyBoxObj)

// ─── Box edge dotted lines during active session ───────────────────────────
plot(showAsia   and not na(asiaBoxHi)   and inAsiaSessionRange   ? asiaBoxHi   : na, "Asia Hi",   color = color.green,  style = plot.style_circles, linewidth = 1)
plot(showAsia   and not na(asiaBoxLo)   and inAsiaSessionRange   ? asiaBoxLo   : na, "Asia Lo",   color = color.green,  style = plot.style_circles, linewidth = 1)
plot(showLondon and not na(londonBoxHi) and inLondonSessionRange ? londonBoxHi : na, "London Hi", color = color.blue,   style = plot.style_circles, linewidth = 1)
plot(showLondon and not na(londonBoxLo) and inLondonSessionRange ? londonBoxLo : na, "London Lo", color = color.blue,   style = plot.style_circles, linewidth = 1)
plot(showNY     and not na(nyBoxHi)     and inNYSessionRange     ? nyBoxHi     : na, "NY Hi",     color = color.orange, style = plot.style_circles, linewidth = 1)
plot(showNY     and not na(nyBoxLo)     and inNYSessionRange     ? nyBoxLo     : na, "NY Lo",     color = color.orange, style = plot.style_circles, linewidth = 1)

// ─── Trade type with line + label refs (follow-current-bar labels) ─────────
type Trade
    float entry
    float sl
    float tp
    int   dir
    int   barOpen
    line  slLine
    line  tpLine
    line  entryLine
    label slLab
    label tpLab
    label enLab

// ─── Per-session stats vars ────────────────────────────────────────────────
var array<Trade> asiaOpen   = array.new<Trade>()
var int   asiaTotalWin    = 0       // cumulative (lookback)
var int   asiaTotalLoss   = 0
var int   asiaChopDays    = 0
var float asiaNetPL       = 0.0
var int   asiaTodayWin    = 0       // today-only (resets midnight)
var int   asiaTodayLoss   = 0
var float asiaTodayPL     = 0.0
var int   asiaTodayAtt    = 0
var int   asiaBkDir       = 0
var float asiaExtreme     = na
var bool  asiaHadEntry    = false
var bool  asiaSessionDone = false
var int   asiaLastDay     = -1

var array<Trade> londonOpen = array.new<Trade>()
var int   londonTotalWin = 0
var int   londonTotalLoss= 0
var int   londonChopDays = 0
var float londonNetPL    = 0.0
var int   londonTodayWin = 0
var int   londonTodayLoss= 0
var float londonTodayPL  = 0.0
var int   londonTodayAtt = 0
var int   londonBkDir    = 0
var int   londonBkBar    = na
var bool  londonHadEntry = false
var int   londonLastDay  = -1

var array<Trade> nyOpen = array.new<Trade>()
var int   nyTotalWin   = 0
var int   nyTotalLoss  = 0
var int   nyChopDays   = 0
var float nyNetPL      = 0.0
var int   nyTodayWin   = 0
var int   nyTodayLoss  = 0
var float nyTodayPL    = 0.0
var int   nyTodayAtt   = 0
var bool  nyEntered    = false
var bool  nyHadEntry   = false
var int   nyLastDay    = -1

// ─── New-day reset ─────────────────────────────────────────────────────────
curDay   = dayofmonth(time, "America/New_York")
newDayET = mod == 0

if newDayET
    if asiaLastDay != -1 and not asiaHadEntry
        asiaChopDays += 1
    asiaLastDay     := curDay
    asiaBkDir       := 0
    asiaExtreme     := na
    asiaTodayAtt    := 0
    asiaTodayWin    := 0
    asiaTodayLoss   := 0
    asiaTodayPL     := 0.0
    asiaHadEntry    := false
    asiaSessionDone := false
    if londonLastDay != -1 and not londonHadEntry
        londonChopDays += 1
    londonLastDay   := curDay
    londonBkDir     := 0
    londonBkBar     := na
    londonTodayAtt  := 0
    londonTodayWin  := 0
    londonTodayLoss := 0
    londonTodayPL   := 0.0
    londonHadEntry  := false
    if nyLastDay != -1 and not nyHadEntry
        nyChopDays   += 1
    nyLastDay       := curDay
    nyEntered       := false
    nyTodayAtt      := 0
    nyTodayWin      := 0
    nyTodayLoss     := 0
    nyTodayPL       := 0.0
    nyHadEntry      := false

    // Defensive: reset box state to prevent cross-day leak
    // Bug observed in replay mode: tmp accumulators sometimes carry
    // stale value from previous day if exact "box close" minute (e.g. 9:08 ET)
    // is missed due to data gap, holiday, or replay quirk.
    asiaBxHiTmp := na
    asiaBxLoTmp := na
    asiaBoxHi   := na
    asiaBoxLo   := na
    asiaBoxBar  := na

    londonBxHiTmp := na
    londonBxLoTmp := na
    londonBoxHi   := na
    londonBoxLo   := na
    londonBoxBar  := na

    nyBxHiTmp := na
    nyBxLoTmp := na
    nyBoxHi   := na
    nyBoxLo   := na
    nyBoxBar  := na

// ─── Process open trades: extend SL/TP lines + move labels + check exit ───
processOpenTrades(arr, sessionTag) =>
    int win    = 0
    int loss   = 0
    float pl   = 0.0
    if array.size(arr) > 0
        i = 0
        while i < array.size(arr)
            t = array.get(arr, i)
            // Extend SL/TP/entry lines to current bar (dynamic length)
            if not na(t.slLine)
                line.set_x2(t.slLine, bar_index)
            if not na(t.tpLine)
                line.set_x2(t.tpLine, bar_index)
            if not na(t.entryLine)
                line.set_x2(t.entryLine, bar_index)
            // Move labels to current bar (always visible at right edge)
            if not na(t.slLab)
                label.set_x(t.slLab, bar_index)
            if not na(t.tpLab)
                label.set_x(t.tpLab, bar_index)
            if not na(t.enLab)
                label.set_x(t.enLab, bar_index)
            // Check exit
            exited = false
            isWin = false
            if t.dir == 1
                if low <= t.sl
                    loss += 1
                    pl   += t.sl - t.entry
                    exited := true
                else if high >= t.tp
                    win  += 1
                    pl   += t.tp - t.entry
                    exited := true
                    isWin := true
            else
                if high >= t.sl
                    loss += 1
                    pl   += t.entry - t.sl
                    exited := true
                else if low <= t.tp
                    win  += 1
                    pl   += t.entry - t.tp
                    exited := true
                    isWin := true
            if exited
                // Lock lines at exit bar (no further extension)
                if not na(t.slLine)
                    line.set_x2(t.slLine, bar_index)
                if not na(t.tpLine)
                    line.set_x2(t.tpLine, bar_index)
                // De-clutter: delete SL/TP/Entry labels on exit
                // (lines stay for historical review; W/L marker added below)
                if not na(t.slLab)
                    label.delete(t.slLab)
                if not na(t.tpLab)
                    label.delete(t.tpLab)
                if not na(t.enLab)
                    label.delete(t.enLab)
                // W/L exit marker (small, frozen at exit bar)
                if showExitMarker
                    markerColor = isWin ? color.lime : color.red
                    markerText  = isWin ? "✓ W " + sessionTag : "✗ L " + sessionTag
                    label.new(x = bar_index,
                         y = isWin ? (t.dir == 1 ? high : low) : (t.dir == 1 ? low : high),
                         text = markerText,
                         color = markerColor, textcolor = color.white,
                         style = isWin ? label.style_label_left : label.style_label_left,
                         size = size.tiny)
                array.remove(arr, i)
                continue
            i += 1
    [win, loss, pl]

[asiaW,   asiaL,   asiaP]   = processOpenTrades(asiaOpen,   "A")
[londonW, londonL, londonP] = processOpenTrades(londonOpen, "L")
[nyW,     nyL,     nyP]     = processOpenTrades(nyOpen,     "NY")

// Cumulative (lookback-gated)
if inLookback
    asiaTotalWin   += asiaW
    asiaTotalLoss  += asiaL
    asiaNetPL      += asiaP
    londonTotalWin += londonW
    londonTotalLoss+= londonL
    londonNetPL    += londonP
    nyTotalWin     += nyW
    nyTotalLoss    += nyL
    nyNetPL        += nyP

// Today (always — resets midnight)
asiaTodayWin    += asiaW
asiaTodayLoss   += asiaL
asiaTodayPL     += asiaP
londonTodayWin  += londonW
londonTodayLoss += londonL
londonTodayPL   += londonP
nyTodayWin      += nyW
nyTodayLoss     += nyL
nyTodayPL       += nyP

// ─── Entry helpers ─────────────────────────────────────────────────────────
// Creates SL line (red, dashed, width 3), TP line (green, solid, width 3),
// entry midline (white, dotted, width 1), and FOLLOW-CURRENT-BAR labels
// showing price + pt distance + ⚠️ warning if SL distance abnormally wide
mkEntryViz(slPx, tpPx, entryPx, slCol, tpCol) =>
    slL  = showLevels ? line.new(bar_index, slPx,   bar_index, slPx,    color = slCol,                       width = 3, style = line.style_dashed) : na
    tpL  = showLevels ? line.new(bar_index, tpPx,   bar_index, tpPx,    color = tpCol,                       width = 3, style = line.style_solid)  : na
    // Hide entry midline in minimal mode
    entL = (showLevels and not minimalLabels) ? line.new(bar_index, entryPx, bar_index, entryPx, color = color.new(color.white, 30), width = 1, style = line.style_dotted) : na

    slDist  = math.abs(entryPx - slPx)
    tpDist  = math.abs(entryPx - tpPx)
    slWarn  = slDist > 30 ? " ⚠️" : ""
    // Minimal mode: shorter label text (no distance, no warning)
    slText = minimalLabels ? "SL " + str.tostring(slPx, "#.##") :
             "SL " + str.tostring(slPx, "#.##") + " (-" + str.tostring(slDist, "#.#") + "pt loss)" + slWarn
    tpText = minimalLabels ? "TP " + str.tostring(tpPx, "#.##") :
             "TP " + str.tostring(tpPx, "#.##") + " (+" + str.tostring(tpDist, "#.#") + "pt gain)"
    slLab = showLevels ? label.new(x = bar_index, y = slPx,
         text      = slText,
         color     = slCol,
         textcolor = color.white,
         style     = label.style_label_left,
         size      = minimalLabels ? size.tiny : size.small) : na
    tpLab = showLevels ? label.new(x = bar_index, y = tpPx,
         text      = tpText,
         color     = tpCol,
         textcolor = color.white,
         style     = label.style_label_left,
         size      = minimalLabels ? size.tiny : size.small) : na
    // Hide entry-price label in minimal mode
    enLab = (showLevels and not minimalLabels) ? label.new(x = bar_index, y = entryPx,
         text      = "@ " + str.tostring(entryPx, "#.##"),
         color     = color.gray,
         textcolor = color.white,
         style     = label.style_label_left,
         size      = size.small) : na
    [slL, tpL, entL, slLab, tpLab, enLab]

drawEntryLabel(txt, ypos, isLong, col) =>
    if showSignals
        label.new(x = bar_index, y = ypos, text = txt,
             color = col, textcolor = color.white,
             style = isLong ? label.style_label_up : label.style_label_down,
             size = size.small)

// ─── Risk filter helpers ───────────────────────────────────────────────────
// Compute suggested lot size based on risk budget + SL distance
// XAUUSD: 1 lot × 1pt = $100 PnL → suggested_lot = riskUsd / slPts / 100
suggestedLot(slDist) =>
    raw = riskPerTradeUsd / slDist / 100
    math.max(0.01, math.round(raw * 100) / 100)  // round to 0.01 broker step

// Build risk-info string for entry label
riskInfo(slDist) =>
    lossUsd = slDist * 0.02 * 100  // assuming current 0.02 lot
    pctCap  = lossUsd / capUsd * 100
    sugLot  = suggestedLot(slDist)
    sugLotLossUsd = slDist * sugLot * 100
    "💰 @ 0.02 lot = -$" + str.tostring(lossUsd, "#.##") + " (" + str.tostring(pctCap, "#.#") + "% cap)" +
         (showLotSuggest ? "\n📐 Sug lot " + str.tostring(sugLot, "#.##") + " = -$" + str.tostring(sugLotLossUsd, "#.##") : "")

// Draw "🚫 SKIP" label when SL exceeds max
drawSkipLabel(slDist, sessionTag, ypos, isLong) =>
    if showSignals
        label.new(x = bar_index, y = ypos,
             text  = "🚫 SKIP " + sessionTag + "\nSL " + str.tostring(slDist, "#.#") + "pt > " + str.tostring(maxSlPts, "#.#") + "pt max",
             color = color.new(color.red, 30), textcolor = color.white,
             style = isLong ? label.style_label_up : label.style_label_down,
             size  = size.tiny)

// ─── Asia entry: A2-fail mean-reversion ────────────────────────────────────
if showAsia and inAsiaSessionRange and not na(asiaBoxHi) and not asiaSessionDone
    asiaSessionDone := asiaTodayAtt >= asiaMaxAttempt or
                       (asiaTodayAtt > 0 and asiaW > 0) or
                       asiaL >= 2 ? true : asiaSessionDone

if showAsia and inAsiaSessionRange and not na(asiaBoxHi) and not asiaSessionDone
    if asiaBkDir == 0
        if close > asiaBoxHi
            asiaBkDir   := 1
            asiaExtreme := high
        else if close < asiaBoxLo
            asiaBkDir   := -1
            asiaExtreme := low
    else if asiaBkDir == 1
        asiaExtreme := math.max(asiaExtreme, high)
        if close < asiaBoxHi and close > asiaBoxLo
            if asiaTodayAtt < asiaMaxAttempt
                boxMid = (asiaBoxHi + asiaBoxLo) / 2.0
                slPx   = asiaExtreme + asiaSlBuffer
                tpPx   = boxMid
                slDist = math.abs(close - slPx)
                if useMaxSlFilter and slDist > maxSlPts
                    drawSkipLabel(slDist, "Asia", high, false)
                else
                    asiaTodayAtt += 1
                    asiaHadEntry := true
                    [slL, tpL, entL, slLab, tpLab, enLab] = mkEntryViz(slPx, tpPx, close, color.red, color.green)
                    array.push(asiaOpen, Trade.new(close, slPx, tpPx, -1, bar_index, slL, tpL, entL, slLab, tpLab, enLab))
                    drawEntryLabel("🔴 SELL · Asia Fade ▼\n@ " + str.tostring(close, "#.##") + "\nSL " + str.tostring(slPx, "#.##") + "\nTP " + str.tostring(tpPx, "#.##") + "\n" + riskInfo(slDist), high, false, color.green)
                    alert("🔴 SELL Asia Fade @ " + str.tostring(close) + " | SL " + str.tostring(slPx) + " | TP " + str.tostring(tpPx) + " | Lot " + str.tostring(suggestedLot(slDist), "#.##"), alert.freq_once_per_bar)
            asiaBkDir   := 0
            asiaExtreme := na
    else if asiaBkDir == -1
        asiaExtreme := math.min(asiaExtreme, low)
        if close > asiaBoxLo and close < asiaBoxHi
            if asiaTodayAtt < asiaMaxAttempt
                boxMid = (asiaBoxHi + asiaBoxLo) / 2.0
                slPx   = asiaExtreme - asiaSlBuffer
                tpPx   = boxMid
                slDist = math.abs(close - slPx)
                if useMaxSlFilter and slDist > maxSlPts
                    drawSkipLabel(slDist, "Asia", low, true)
                else
                    asiaTodayAtt += 1
                    asiaHadEntry := true
                    [slL, tpL, entL, slLab, tpLab, enLab] = mkEntryViz(slPx, tpPx, close, color.red, color.green)
                    array.push(asiaOpen, Trade.new(close, slPx, tpPx, 1, bar_index, slL, tpL, entL, slLab, tpLab, enLab))
                    drawEntryLabel("🟢 BUY · Asia Fade ▲\n@ " + str.tostring(close, "#.##") + "\nSL " + str.tostring(slPx, "#.##") + "\nTP " + str.tostring(tpPx, "#.##") + "\n" + riskInfo(slDist), low, true, color.green)
                    alert("🟢 BUY Asia Fade @ " + str.tostring(close) + " | SL " + str.tostring(slPx) + " | TP " + str.tostring(tpPx) + " | Lot " + str.tostring(suggestedLot(slDist), "#.##"), alert.freq_once_per_bar)
            asiaBkDir   := 0
            asiaExtreme := na

// ─── London entry: breakout-pullback + any pattern ─────────────────────────
if showLondon and inLondonSessionRange and not na(londonBoxHi) and londonTodayAtt < londonMaxAttempt
    if londonBkDir == 0
        if close > londonBoxHi
            londonBkDir := 1
            londonBkBar := bar_index
        else if close < londonBoxLo
            londonBkDir := -1
            londonBkBar := bar_index
    else if londonBkDir == 1 and bar_index > londonBkBar
        if low <= londonBoxHi and close > londonBoxHi
            if anyBullPattern(open[1], high[1], low[1], close[1], open, high, low, close)
                bw     = londonBoxHi - londonBoxLo
                slDist = math.max(londonMinSl, londonSlBoxMult * bw)
                slPx   = low - slDist
                tp1Px  = close + londonTp1Mult * slDist
                tp2Px  = close + londonTp2Mult * slDist
                slDistFromEntry = math.abs(close - slPx)
                if useMaxSlFilter and slDistFromEntry > maxSlPts
                    drawSkipLabel(slDistFromEntry, "London", low, true)
                else
                    londonTodayAtt += 1
                    londonHadEntry := true
                    [slL, tpL, entL, slLab, tpLab, enLab] = mkEntryViz(slPx, tp2Px, close, color.red, color.green)
                    array.push(londonOpen, Trade.new(close, slPx, tp2Px, 1, bar_index, slL, tpL, entL, slLab, tpLab, enLab))
                    drawEntryLabel("🟢 BUY · London ▲\n@ " + str.tostring(close, "#.##") + "\nSL " + str.tostring(slPx, "#.##") + "\nTP1 " + str.tostring(tp1Px, "#.##") + "\nTP2 " + str.tostring(tp2Px, "#.##") + "\n" + riskInfo(slDistFromEntry), low, true, color.blue)
                    alert("🟢 BUY London @ " + str.tostring(close) + " | SL " + str.tostring(slPx) + " | TP1 " + str.tostring(tp1Px) + " | TP2 " + str.tostring(tp2Px) + " | Lot " + str.tostring(suggestedLot(slDistFromEntry), "#.##"), alert.freq_once_per_bar)
                londonBkDir := 0
    else if londonBkDir == -1 and bar_index > londonBkBar
        if high >= londonBoxLo and close < londonBoxLo
            if anyBearPattern(open[1], high[1], low[1], close[1], open, high, low, close)
                bw     = londonBoxHi - londonBoxLo
                slDist = math.max(londonMinSl, londonSlBoxMult * bw)
                slPx   = high + slDist
                tp1Px  = close - londonTp1Mult * slDist
                tp2Px  = close - londonTp2Mult * slDist
                slDistFromEntry = math.abs(close - slPx)
                if useMaxSlFilter and slDistFromEntry > maxSlPts
                    drawSkipLabel(slDistFromEntry, "London", high, false)
                else
                    londonTodayAtt += 1
                    londonHadEntry := true
                    [slL, tpL, entL, slLab, tpLab, enLab] = mkEntryViz(slPx, tp2Px, close, color.red, color.green)
                    array.push(londonOpen, Trade.new(close, slPx, tp2Px, -1, bar_index, slL, tpL, entL, slLab, tpLab, enLab))
                    drawEntryLabel("🔴 SELL · London ▼\n@ " + str.tostring(close, "#.##") + "\nSL " + str.tostring(slPx, "#.##") + "\nTP1 " + str.tostring(tp1Px, "#.##") + "\nTP2 " + str.tostring(tp2Px, "#.##") + "\n" + riskInfo(slDistFromEntry), high, false, color.blue)
                    alert("🔴 SELL London @ " + str.tostring(close) + " | SL " + str.tostring(slPx) + " | TP1 " + str.tostring(tp1Px) + " | TP2 " + str.tostring(tp2Px) + " | Lot " + str.tostring(suggestedLot(slDistFromEntry), "#.##"), alert.freq_once_per_bar)
                londonBkDir := 0

// ─── NY entry: direct breakout + pattern-at-breakout ───────────────────────
if showNY and inNYSessionRange and not na(nyBoxHi) and not nyEntered and nyTodayAtt < nyMaxAttempt
    if close > nyBoxHi and anyBullPattern(open[1], high[1], low[1], close[1], open, high, low, close)
        bw     = nyBoxHi - nyBoxLo
        slDist = math.max(nyMinSl, nySlBoxMult * bw)
        slPx   = nyBoxLo - slDist
        tp1Px  = close + nyTp1Mult  * slDist
        tp2Px  = close + nyTp2Mult  * slDist
        slDistFromEntry = math.abs(close - slPx)
        if useMaxSlFilter and slDistFromEntry > maxSlPts
            drawSkipLabel(slDistFromEntry, "NY", low, true)
        else
            nyTodayAtt += 1
            nyHadEntry := true
            nyEntered  := true
            [slL, tpL, entL, slLab, tpLab, enLab] = mkEntryViz(slPx, tp2Px, close, color.red, color.green)
            array.push(nyOpen, Trade.new(close, slPx, tp2Px, 1, bar_index, slL, tpL, entL, slLab, tpLab, enLab))
            drawEntryLabel("🟢 BUY · NY ▲ DIRECT\n@ " + str.tostring(close, "#.##") + "\nSL " + str.tostring(slPx, "#.##") + "\nTP1 " + str.tostring(tp1Px, "#.##") + "\nTP2 " + str.tostring(tp2Px, "#.##") + "\n" + riskInfo(slDistFromEntry), low, true, color.orange)
            alert("🟢 BUY NY Direct @ " + str.tostring(close) + " | SL " + str.tostring(slPx) + " | TP1 " + str.tostring(tp1Px) + " | TP2 " + str.tostring(tp2Px) + " | Lot " + str.tostring(suggestedLot(slDistFromEntry), "#.##"), alert.freq_once_per_bar)
    else if close < nyBoxLo and anyBearPattern(open[1], high[1], low[1], close[1], open, high, low, close)
        bw     = nyBoxHi - nyBoxLo
        slDist = math.max(nyMinSl, nySlBoxMult * bw)
        slPx   = nyBoxHi + slDist
        tp1Px  = close - nyTp1Mult  * slDist
        tp2Px  = close - nyTp2Mult  * slDist
        slDistFromEntry = math.abs(close - slPx)
        if useMaxSlFilter and slDistFromEntry > maxSlPts
            drawSkipLabel(slDistFromEntry, "NY", high, false)
        else
            nyTodayAtt += 1
            nyHadEntry := true
            nyEntered  := true
            [slL, tpL, entL, slLab, tpLab, enLab] = mkEntryViz(slPx, tp2Px, close, color.red, color.green)
            array.push(nyOpen, Trade.new(close, slPx, tp2Px, -1, bar_index, slL, tpL, entL, slLab, tpLab, enLab))
            drawEntryLabel("🔴 SELL · NY ▼ DIRECT\n@ " + str.tostring(close, "#.##") + "\nSL " + str.tostring(slPx, "#.##") + "\nTP1 " + str.tostring(tp1Px, "#.##") + "\nTP2 " + str.tostring(tp2Px, "#.##") + "\n" + riskInfo(slDistFromEntry), high, false, color.orange)
            alert("🔴 SELL NY Direct @ " + str.tostring(close) + " | SL " + str.tostring(slPx) + " | TP1 " + str.tostring(tp1Px) + " | TP2 " + str.tostring(tp2Px) + " | Lot " + str.tostring(suggestedLot(slDistFromEntry), "#.##"), alert.freq_once_per_bar)

// ─── Stats Panel ───────────────────────────────────────────────────────────
if showStatsPanel and barstate.islast
    var table stats = table.new(position.top_right, 4, 13,
         bgcolor      = color.new(color.black, 70),
         border_color = color.new(color.purple, 50),
         border_width = 1)

    // Pick stats source based on mode
    isToday   = statsMode == "Today"
    asiaW_d   = isToday ? asiaTodayWin    : asiaTotalWin
    asiaL_d   = isToday ? asiaTodayLoss   : asiaTotalLoss
    asiaPL_d  = isToday ? asiaTodayPL     : asiaNetPL
    londonW_d = isToday ? londonTodayWin  : londonTotalWin
    londonL_d = isToday ? londonTodayLoss : londonTotalLoss
    londonPL_d= isToday ? londonTodayPL   : londonNetPL
    nyW_d     = isToday ? nyTodayWin      : nyTotalWin
    nyL_d     = isToday ? nyTodayLoss     : nyTotalLoss
    nyPL_d    = isToday ? nyTodayPL       : nyNetPL
    modeLabel = isToday ? "TODAY" : str.tostring(panelLookback) + "d"

    table.cell(stats, 0, 0, "PT BOX",  text_color = color.yellow, bgcolor = color.new(color.purple, 60), text_size = size.small)
    table.cell(stats, 1, 0, "ASIA",    text_color = color.lime,   bgcolor = color.new(color.purple, 60), text_size = size.small)
    table.cell(stats, 2, 0, "LONDON",  text_color = color.aqua,   bgcolor = color.new(color.purple, 60), text_size = size.small)
    table.cell(stats, 3, 0, "NY",      text_color = color.orange, bgcolor = color.new(color.purple, 60), text_size = size.small)

    table.cell(stats, 0, 1, "Win", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 1, str.tostring(asiaW_d),   text_color = color.lime, text_size = size.tiny)
    table.cell(stats, 2, 1, str.tostring(londonW_d), text_color = color.lime, text_size = size.tiny)
    table.cell(stats, 3, 1, str.tostring(nyW_d),     text_color = color.lime, text_size = size.tiny)

    table.cell(stats, 0, 2, "Loss", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 2, str.tostring(asiaL_d),   text_color = color.red, text_size = size.tiny)
    table.cell(stats, 2, 2, str.tostring(londonL_d), text_color = color.red, text_size = size.tiny)
    table.cell(stats, 3, 2, str.tostring(nyL_d),     text_color = color.red, text_size = size.tiny)

    table.cell(stats, 0, 3, "Chop Days", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 3, str.tostring(asiaChopDays),   text_color = color.yellow, text_size = size.tiny)
    table.cell(stats, 2, 3, str.tostring(londonChopDays), text_color = color.yellow, text_size = size.tiny)
    table.cell(stats, 3, 3, str.tostring(nyChopDays),     text_color = color.yellow, text_size = size.tiny)

    asiaWR   = asiaW_d   + asiaL_d   > 0 ? 100.0 * asiaW_d   / (asiaW_d   + asiaL_d)   : 0.0
    londonWR = londonW_d + londonL_d > 0 ? 100.0 * londonW_d / (londonW_d + londonL_d) : 0.0
    nyWR     = nyW_d     + nyL_d     > 0 ? 100.0 * nyW_d     / (nyW_d     + nyL_d)     : 0.0
    table.cell(stats, 0, 4, "Win Rate", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 4, str.tostring(asiaWR,   "#.#") + "%", text_color = asiaWR   >= 50 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 2, 4, str.tostring(londonWR, "#.#") + "%", text_color = londonWR >= 50 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 3, 4, str.tostring(nyWR,     "#.#") + "%", text_color = nyWR     >= 50 ? color.lime : color.red, text_size = size.tiny)

    table.cell(stats, 0, 5, "Net P&L (pts)", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 5, str.tostring(asiaPL_d,   "#.#"), text_color = asiaPL_d   >= 0 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 2, 5, str.tostring(londonPL_d, "#.#"), text_color = londonPL_d >= 0 ? color.lime : color.red, text_size = size.tiny)
    table.cell(stats, 3, 5, str.tostring(nyPL_d,     "#.#"), text_color = nyPL_d     >= 0 ? color.lime : color.red, text_size = size.tiny)

    table.cell(stats, 0, 6, "RR (TP/SL)", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 6, "1:1.5",                                   text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 6, "1:" + str.tostring(londonTp2Mult, "#.#"), text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 6, "1:" + str.tostring(nyTp2Mult,     "#.#"), text_color = color.white, text_size = size.tiny)

    table.cell(stats, 0, 7, "SL/TP1/TP2", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 7, "ext+1 / mid",      text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 7, "0.5×bw / 3R / 6R", text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 7, "0.5×bw / 3R / 6R", text_color = color.white, text_size = size.tiny)

    table.cell(stats, 0, 8, "Max Attempt", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 8, str.tostring(asiaMaxAttempt)   + "x", text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 8, str.tostring(londonMaxAttempt) + "x", text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 8, str.tostring(nyMaxAttempt)     + "x", text_color = color.white, text_size = size.tiny)

    table.cell(stats, 0, 9, "Today Attempt", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 9, str.tostring(asiaTodayAtt)   + "/" + str.tostring(asiaMaxAttempt),   text_color = color.white, text_size = size.tiny)
    table.cell(stats, 2, 9, str.tostring(londonTodayAtt) + "/" + str.tostring(londonMaxAttempt), text_color = color.white, text_size = size.tiny)
    table.cell(stats, 3, 9, str.tostring(nyTodayAtt)     + "/" + str.tostring(nyMaxAttempt),     text_color = color.white, text_size = size.tiny)

    asiaDirStr   = asiaBkDir   == 1 ? "LONG" : asiaBkDir   == -1 ? "SHORT" : "—"
    londonDirStr = londonBkDir == 1 ? "LONG" : londonBkDir == -1 ? "SHORT" : "—"
    nyDirStr     = nyEntered ? "FIRED" : "—"
    table.cell(stats, 0, 10, "Breakout Dir", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 10, asiaDirStr,   text_color = asiaBkDir   == 1 ? color.lime : asiaBkDir   == -1 ? color.red : color.gray, text_size = size.tiny)
    table.cell(stats, 2, 10, londonDirStr, text_color = londonBkDir == 1 ? color.lime : londonBkDir == -1 ? color.red : color.gray, text_size = size.tiny)
    table.cell(stats, 3, 10, nyDirStr,     text_color = nyEntered ? color.orange : color.gray, text_size = size.tiny)

    asiaInTrade   = array.size(asiaOpen)   > 0
    londonInTrade = array.size(londonOpen) > 0
    nyInTrade     = array.size(nyOpen)     > 0
    table.cell(stats, 0, 11, "In Trade", text_color = color.gray, text_size = size.tiny)
    table.cell(stats, 1, 11, asiaInTrade   ? "YES" : "NO", text_color = asiaInTrade   ? color.lime : color.gray, text_size = size.tiny)
    table.cell(stats, 2, 11, londonInTrade ? "YES" : "NO", text_color = londonInTrade ? color.lime : color.gray, text_size = size.tiny)
    table.cell(stats, 3, 11, nyInTrade     ? "YES" : "NO", text_color = nyInTrade     ? color.lime : color.gray, text_size = size.tiny)

    table.cell(stats, 0, 12, "Mode",                  text_color = color.gray,   text_size = size.tiny)
    table.cell(stats, 1, 12, modeLabel,               text_color = color.aqua,   text_size = size.tiny)
    table.cell(stats, 2, 12, "e20d",                  text_color = color.yellow, text_size = size.tiny)
    table.cell(stats, 3, 12, "+976/+1206",            text_color = color.lime,   text_size = size.tiny)

// ─── Optional info panel (bottom-right) ────────────────────────────────────
if showInfoPanel and barstate.islast
    var table info = table.new(position.bottom_right, 2, 5,
         bgcolor = color.new(color.black, 80), border_color = color.gray, border_width = 1)
    table.cell(info, 0, 0, "PT Box e20d",       text_color = color.yellow, bgcolor = color.new(color.black, 70))
    table.cell(info, 1, 0, "+976 / +1206 OOS",  text_color = color.lime,   bgcolor = color.new(color.black, 70))
    table.cell(info, 0, 1, "Asia 21-23 ET",     text_color = color.green)
    table.cell(info, 1, 1, "Mean-rev fade",     text_color = color.white)
    table.cell(info, 0, 2, "London 1-5 ET",     text_color = color.blue)
    table.cell(info, 1, 2, "Pullback + pattern",text_color = color.white)
    table.cell(info, 0, 3, "NY 9-12 ET",        text_color = color.orange)
    table.cell(info, 1, 3, "Direct + pattern",  text_color = color.white)
    table.cell(info, 0, 4, "Lot @ $200 cap",    text_color = color.gray)
    table.cell(info, 1, 4, "0.02",              text_color = color.aqua)
